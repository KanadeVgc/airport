{
  "name": "airport-backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "prisma": "node ./node_modules/prisma/build/index.js",
    "postinstall": "npm run prisma -- generate",
    "db:generate": "npm run prisma -- generate",
    "db:migrate": "npm run prisma -- migrate dev",
    "db:deploy": "npm run prisma -- migrate deploy",
    "db:fix-user-username": "npm run prisma -- db execute --file prisma/migrations/20260415143000_user_add_username_column/migration.sql"
  },
  "dependencies": {
    "cloudinary": "^2.5.1",
    "@aws-sdk/client-s3": "^3.887.0",
    "@aws-sdk/s3-request-presigner": "^3.887.0",
    "@prisma/client": "^6.16.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "slugify": "^1.6.6",
    "zod": "^4.1.5",
    "prisma": "^6.16.0"
  }
}

PORT=8787
NODE_ENV=development

# Local Postgres (docker-compose)
DATABASE_URL=postgresql://airport:airport@localhost:5432/airport?schema=public

# Change this
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# Frontend origin(s), comma-separated
CORS_ORIGIN=http://localhost:5173

# 上傳：local = 檔案在後端 uploads/（開發預設，不必設定 R2）
#       r2  = Cloudflare R2 / S3 預簽名（需填下方 S3_*；專案根 .env 設 VITE_STORAGE_DRIVER=r2）
#       cloudinary = 後端代傳 Cloudinary（需填下方 CLOUDINARY_*；前端勿設 VITE_STORAGE_DRIVER=r2）
STORAGE_DRIVER=local
# multipart 上傳大小上限（bytes），預設 120MB。超過會回 413。
# 例如 500MB：UPLOAD_MAX_BYTES=524288000
UPLOAD_MAX_BYTES=
# 本機模式時，瀏覽器要能開到此網址看圖/影片
API_PUBLIC_URL=http://localhost:8787

# --- 僅當 STORAGE_DRIVER=r2 時必填 ---
# Cloudflare R2（S3 相容）。不要結尾斜線。
S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=airport
S3_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID
S3_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY
S3_PUBLIC_BASE_URL=https://pub-xxxxxxxxxxxx.r2.dev

# --- 僅當 STORAGE_DRIVER=cloudinary 時必填 ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=


PORT=8787
NODE_ENV=development

# Local Postgres (docker-compose)
DATABASE_URL=postgresql://airport:airport@localhost:5432/airport?schema=public

JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

CORS_ORIGIN=http://localhost:5173

# 上傳：本機開發用 local（檔案在 backend/uploads，不必設定真 R2）
STORAGE_DRIVER=local
API_PUBLIC_URL=http://localhost:8787

# 若改為 STORAGE_DRIVER=r2，請改成真實值並在專案根 .env 設 VITE_STORAGE_DRIVER=r2
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
